DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
ONLINE_DASHBOARD_MODE=snapshot
PUBLIC_DASHBOARD_INGEST_TOKEN=change-me-long-random-token
PUBLIC_DASHBOARD_USERNAME=change-me
PUBLIC_DASHBOARD_PASSWORD=change-me-strong-password
PUBLIC_DASHBOARD_SESSION_SECRET=change-me-long-random-session-secret
PUBLIC_DASHBOARD_SHOW_MONEY=1
PUBLIC_DASHBOARD_PUBLIC=0
