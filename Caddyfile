{
	admin off
}

(asset_cache) {
	@versioned_assets path /assets/*
	header @versioned_assets Cache-Control "public, max-age=31536000, immutable"
	@static_assets path /static/*
	header @static_assets Cache-Control "public, max-age=3600, must-revalidate"
}

online.lilletorget.net {
	encode zstd gzip
	import asset_cache

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy online_dashboard:8111 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

owntracks.lilletorget.net {
	encode zstd gzip
	import asset_cache

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	@internal_api path /api/owntracks /api/owntracks/*
	respond @internal_api "Not found" 404

	reverse_proxy owntracks_service:8128 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

